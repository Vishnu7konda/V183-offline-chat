{
  "version": 2,
  "builds": [
    {
      "src": "nexus_chat/wsgi.py",
      "use": "@vercel/python",
      "config": {
        "maxLambdaSize": "50mb",
        "runtime": "python3.11"
      }
    }
  ],
  "routes": [
    {
      "src": "/static/(.*)",
      "dest": "/static/$1"
    },
    {
      "src": "/(.*)",
      "dest": "nexus_chat/wsgi.py"
    }
  ],
  "env": {
    "DJANGO_SETTINGS_MODULE": "nexus_chat.settings.prod"
  }
}
